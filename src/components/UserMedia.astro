<video class="cc-user-media"></video>

<script>
    for (const $c of document.querySelectorAll('.cc-user-media')) {
        navigator.mediaDevices.getUserMedia({ video: true })
        .then((stream) => {
            const video = $c as HTMLVideoElement
            video.srcObject = stream;
            video.onloadedmetadata = () => {
                video.play();
            };
        })
        .catch((error) => {
            console.error('Error accessing user media:', error);
        });
    }
</script>