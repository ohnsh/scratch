---
import { getCollection } from 'astro:content'
import YTDay from './YTDay.astro'

const days = await getCollection('youtube')
days.sort((a, b) => b.id.localeCompare(a.id))
---

{
  days.map(day => {
    return (
        <details>
          <summary>{day.id}</summary>
          <YTDay {day} sort="🏃‍♂️" />
        </details>
    )
  })
}
