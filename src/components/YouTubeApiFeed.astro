---
import { getCollection } from 'astro:content'
import Video from './LiteYTVideo.astro'

const days = await getCollection('youtube')
days.sort((a, b) => b.id.localeCompare(a.id))
---

{
  days.map(({ id: day, data }) => {
    return (
      <article>
        <details>
          <summary>{day}</summary>
          {data.map((video) => {
            return <Video {...video} />
          })}
        </details>
      </article>
    )
  })
}
